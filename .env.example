# URL pública do backend (Next API / outro servidor). Sem barra no final.
# Dev: backend típico na porta 3001; frontend este projeto na 3000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# URL canônica deste frontend (cookies NextAuth / links). Ex.: https://crm.seudominio.com
NEXTAUTH_URL=http://localhost:3000

# Mesmo segredo do backend (JWT da sessão). Obrigatório para middleware/layout ler sessão.
NEXTAUTH_SECRET=defina-o-mesmo-valor-do-backend

# Opcional Auth.js v5 — se definido, igual a NEXTAUTH_SECRET.
# AUTH_SECRET=

# Meta (só variáveis NEXT_PUBLIC se usadas no browser — embedded signup, etc.)
# NEXT_PUBLIC_META_APP_ID=
# NEXT_PUBLIC_META_ES_CONFIG_ID=
