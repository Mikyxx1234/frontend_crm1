# Obrigatório em produção (Easypanel): URL pública do backend, sem barra final.
NEXT_PUBLIC_API_BASE_URL=https://api.seudominio.com

# Obrigatório: URL pública deste frontend (cookies / redirects NextAuth).
NEXTAUTH_URL=https://crm.seudominio.com

# Obrigatório: mesmo valor do backend (JWT da sessão).
NEXTAUTH_SECRET=

# Opcional: Auth.js v5 — se definido, deve ser igual a NEXTAUTH_SECRET.
# AUTH_SECRET=

# Opcional: STUN/TURN para ligação WhatsApp WebRTC (JSON no browser).
# NEXT_PUBLIC_WEBRTC_ICE_SERVERS_JSON=

# Apenas para sandbox do v0.dev: bypass de autenticação no middleware
# (cookies cross-origin do v0 são bloqueados pelo browser, então login
# real nunca persiste). Adiciona um botão "Entrar (preview)" na tela de
# login que pula direto pra rota destino. NUNCA ative em produção.
# NEXT_PUBLIC_PREVIEW_MODE=true
